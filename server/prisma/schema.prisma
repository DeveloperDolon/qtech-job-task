generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id           String        @id @default(uuid())
  title        String
  description  String
  company      String
  location     String
  logo         String
  jobType      JobType
  tags         String[]
  vacancy      Int
  workingTime  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  salary       Float
  category     JobCategory
  applications Application[]
}

model Application {
  id             String            @id @default(uuid())
  jobId          String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  applicantEmail String
  applicantName  String
  coverLetter    String?
  resumeLink     String
  status         ApplicationStatus @default(PENDING)
  job            Job               @relation(fields: [jobId], references: [id])
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum JobCategory {
  SOFTWARE_DEVELOPMENT
  DESIGN
  MARKETING
  SALES
  CUSTOMER_SUPPORT
  HUMAN_RESOURCES
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}
